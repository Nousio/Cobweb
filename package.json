{
  "name": "cobweb-monorepo",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core packages/daemon packages/cli packages/mcp packages/cobweb",
    "check": "tsc -b --pretty false packages/core packages/daemon packages/cli packages/mcp packages/cobweb",
    "test": "vitest run",
    "dev:cli": "tsx packages/cli/src/index.ts",
    "dev:daemon": "tsx packages/daemon/src/index.ts",
    "pack:release": "bash scripts/pack-release.sh",
    "smoke:install": "bash scripts/smoke-install.sh",
    "verify:pack": "bash scripts/verify-pack.sh"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}