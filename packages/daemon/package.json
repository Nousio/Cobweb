{
  "name": "@cobweb/daemon",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/ipc/client.d.ts",
      "import": "./dist/ipc/client.js"
    }
  },
  "bin": {
    "cobwebd": "./dist/index.js"
  },
  "dependencies": {
    "@cobweb/core": "0.1.0"
  },
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b --pretty false"
  }
}